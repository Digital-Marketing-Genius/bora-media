<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>School of Spiritual Growth - 90-Day Bootcamp</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,800;1,400;1,600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --dark: #050A14;
  --red: #C21B1B;
  --red-light: #E53535;
  --light: #F2EFE9;
  --warm: #E5E0D6;
  --sidebar-w: 300px;
  --header-h: 64px;
  --gray: #6B7280;
  --border: rgba(255,255,255,0.08);
  --card-bg: rgba(255,255,255,0.03);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  background: var(--dark);
  color: var(--light);
  font-family: 'Crimson Pro', Georgia, serif;
  font-size: 18px;
  line-height: 1.8;
  overflow-x: hidden;
}

/* ── NOISE ── */
body::before {
  content: '';
  position: fixed; inset: 0; z-index: 999; pointer-events: none;
  mix-blend-mode: overlay; opacity: 0.04;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
}

/* ── TOP NAV ── */
.topnav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  height: var(--header-h);
  background: rgba(5,10,20,0.95);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  display: flex; align-items: center;
  padding: 0 20px 0 0;
  gap: 0;
}
.topnav-brand {
  display: flex; align-items: center; gap: 12px;
  padding: 0 20px;
  text-decoration: none;
  border-right: 1px solid var(--border);
  height: 100%;
  min-width: var(--sidebar-w);
}
.topnav-brand-text {
  display: flex; flex-direction: column;
}
.topnav-brand-name {
  font-family: 'Inter', sans-serif;
  font-size: 0.6rem; font-weight: 700;
  letter-spacing: 0.25em; text-transform: uppercase;
  color: rgba(242,239,233,0.6);
}
.topnav-brand-course {
  font-family: 'Playfair Display', serif;
  font-size: 0.95rem; font-weight: 600;
  color: var(--light);
}
.topnav-center {
  flex: 1;
  display: flex; align-items: center;
  padding: 0 24px;
  gap: 16px;
}
.progress-container {
  flex: 1; max-width: 400px;
}
.progress-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem; color: var(--gray); margin-bottom: 5px;
  display: flex; justify-content: space-between;
}
.progress-bar-track {
  height: 4px; background: rgba(255,255,255,0.1); border-radius: 2px; overflow: hidden;
}
.progress-bar-fill {
  height: 100%; background: var(--red); border-radius: 2px;
  transition: width 0.5s ease;
}
.topnav-day-indicator {
  font-family: 'Inter', sans-serif;
  font-size: 0.7rem; color: var(--gray);
  white-space: nowrap;
}
.topnav-actions {
  display: flex; align-items: center; gap: 10px; margin-left: auto;
}
.btn-journal-top {
  display: flex; align-items: center; gap: 6px;
  background: var(--red); color: white;
  font-family: 'Inter', sans-serif; font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 8px 16px; border-radius: 100px; text-decoration: none;
  transition: all 0.2s ease; border: none; cursor: pointer;
  white-space: nowrap;
}
.btn-journal-top:hover { background: white; color: var(--red); }
.hamburger {
  display: none; background: none; border: none; color: var(--light);
  cursor: pointer; padding: 8px; margin-left: 8px;
}

/* ── LAYOUT ── */
.layout {
  display: flex;
  margin-top: var(--header-h);
  min-height: calc(100vh - var(--header-h));
}

/* ── SIDEBAR ── */
.sidebar {
  width: var(--sidebar-w);
  min-width: var(--sidebar-w);
  height: calc(100vh - var(--header-h));
  position: sticky; top: var(--header-h);
  overflow-y: auto;
  background: rgba(5,10,20,0.98);
  border-right: 1px solid var(--border);
  flex-shrink: 0;
}
.sidebar::-webkit-scrollbar { width: 4px; }
.sidebar::-webkit-scrollbar-track { background: transparent; }
.sidebar::-webkit-scrollbar-thumb { background: #222; border-radius: 2px; }
.sidebar::-webkit-scrollbar-thumb:hover { background: var(--red); }

.sidebar-search {
  padding: 16px;
  border-bottom: 1px solid var(--border);
  position: sticky; top: 0; background: rgba(5,10,20,0.99); z-index: 10;
}
.search-input {
  width: 100%; background: rgba(255,255,255,0.05);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: 8px; padding: 9px 14px;
  color: var(--light); font-family: 'Inter', sans-serif; font-size: 0.78rem;
  outline: none; transition: border-color 0.2s;
}
.search-input::placeholder { color: rgba(255,255,255,0.25); }
.search-input:focus { border-color: var(--red); }

.section-group { border-bottom: 1px solid var(--border); }
.section-title {
  padding: 12px 16px 8px;
  font-family: 'Inter', sans-serif;
  font-size: 0.58rem; font-weight: 700;
  letter-spacing: 0.2em; text-transform: uppercase;
  color: var(--red); cursor: pointer;
  display: flex; justify-content: space-between; align-items: center;
  user-select: none;
}
.section-title:hover { color: #e55; }
.section-chevron { transition: transform 0.25s ease; font-size: 0.7rem; }
.section-collapsed .section-chevron { transform: rotate(-90deg); }
.section-days { overflow: hidden; transition: max-height 0.3s ease; }
.section-collapsed .section-days { max-height: 0 !important; }

.day-item {
  display: flex; align-items: flex-start; gap: 10px;
  padding: 9px 16px;
  cursor: pointer;
  transition: background 0.15s ease;
  text-decoration: none; color: inherit;
  border-left: 3px solid transparent;
}
.day-item:hover { background: rgba(255,255,255,0.04); }
.day-item.active {
  background: rgba(194,27,27,0.12);
  border-left-color: var(--red);
}
.day-item.completed .day-num-badge { background: #166534; color: #86efac; }
.day-num-badge {
  min-width: 28px; height: 28px; border-radius: 6px;
  background: rgba(255,255,255,0.06);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Inter', sans-serif; font-size: 0.65rem; font-weight: 700;
  color: var(--gray); flex-shrink: 0; margin-top: 1px;
  transition: all 0.2s ease;
}
.day-item.active .day-num-badge { background: var(--red); color: white; }
.day-item-title {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem; line-height: 1.4;
  color: rgba(242,239,233,0.65);
  transition: color 0.2s ease;
}
.day-item:hover .day-item-title, .day-item.active .day-item-title {
  color: var(--light);
}

/* ── MAIN CONTENT ── */
.main-content {
  flex: 1;
  min-width: 0;
  padding: 48px 60px 80px;
  max-width: 860px;
}
@media (max-width: 900px) {
  .main-content { padding: 32px 24px 60px; }
}

/* ── DAY HEADER ── */
.day-header {
  margin-bottom: 32px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--border);
}
.day-badge {
  display: inline-flex; align-items: center; gap: 6px;
  background: rgba(194,27,27,0.15);
  border: 1px solid rgba(194,27,27,0.3);
  color: var(--red); border-radius: 100px;
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.2em; text-transform: uppercase;
  padding: 5px 14px; margin-bottom: 14px;
}
.day-title {
  font-family: 'Playfair Display', serif;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 700; line-height: 1.15;
  color: var(--light); margin-bottom: 0;
}

/* ── SCRIPTURE BLOCK ── */
.scripture-block {
  background: rgba(194,27,27,0.08);
  border: 1px solid rgba(194,27,27,0.2);
  border-radius: 12px; padding: 24px 28px;
  margin: 28px 0;
}
.scripture-label {
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--red); display: block; margin-bottom: 14px;
}
.scripture-quote {
  font-family: 'Playfair Display', serif;
  font-size: 1.15rem; font-style: italic;
  color: var(--light); line-height: 1.7;
  border: none; padding: 0; margin: 0;
}
.scripture-quote cite {
  display: block; margin-top: 10px;
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem; font-style: normal;
  font-weight: 600; color: var(--red);
  letter-spacing: 0.05em;
}

/* ── DEVOTIONAL BODY ── */
.devotional-body {
  margin: 24px 0;
}
.devotional-body p {
  font-family: 'Crimson Pro', Georgia, serif;
  font-size: 1.15rem; line-height: 1.85;
  color: rgba(242,239,233,0.85);
  margin-bottom: 20px;
}
.devotional-body p:last-child { margin-bottom: 0; }

/* ── PRAYER BLOCK ── */
.prayer-block {
  background: rgba(255,255,255,0.04);
  border: 1px solid var(--border);
  border-radius: 12px; padding: 24px 28px;
  margin: 32px 0;
}
.prayer-block h4 {
  font-family: 'Inter', sans-serif;
  font-size: 0.75rem; font-weight: 700;
  letter-spacing: 0.15em; text-transform: uppercase;
  color: rgba(242,239,233,0.5); margin-bottom: 14px;
}
.prayer-block p {
  font-family: 'Playfair Display', serif;
  font-size: 1rem; font-style: italic;
  color: rgba(242,239,233,0.75); line-height: 1.85;
}

/* ── VIDEO SECTION ── */
.video-section {
  margin: 40px 0;
}
.section-heading {
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.25em; text-transform: uppercase;
  color: var(--gray); margin-bottom: 16px;
  display: flex; align-items: center; gap: 10px;
}
.section-heading::after {
  content: ''; flex: 1; height: 1px; background: var(--border);
}
.video-wrapper {
  position: relative; padding-bottom: 56.25%; height: 0;
  border-radius: 12px; overflow: hidden;
  border: 1px solid var(--border);
  background: #000;
}
.video-wrapper iframe {
  position: absolute; top: 0; left: 0;
  width: 100%; height: 100%; border: none;
}

/* ── JOURNAL CTA ── */
.journal-section {
  margin: 40px 0;
}
.journal-cta {
  display: flex; align-items: center; justify-content: space-between;
  gap: 20px; flex-wrap: wrap;
  background: linear-gradient(135deg, rgba(194,27,27,0.15) 0%, rgba(194,27,27,0.05) 100%);
  border: 1px solid rgba(194,27,27,0.25);
  border-radius: 14px; padding: 24px 28px;
}
.journal-cta-text h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.2rem; font-weight: 600;
  color: var(--light); margin-bottom: 5px;
}
.journal-cta-text p {
  font-family: 'Inter', sans-serif;
  font-size: 0.8rem; color: var(--gray);
  line-height: 1.5;
}
.btn-journal {
  display: inline-flex; align-items: center; gap: 8px;
  background: var(--red); color: white;
  font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 12px 24px; border-radius: 100px;
  text-decoration: none; white-space: nowrap;
  transition: all 0.25s ease;
  box-shadow: 0 0 24px rgba(194,27,27,0.3);
}
.btn-journal:hover {
  background: white; color: var(--red);
  box-shadow: 0 0 32px rgba(255,255,255,0.15);
}

/* ── RESOURCES ── */
.resources-section { margin: 40px 0 20px; }
.resources-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 14px; margin-top: 16px;
}
.resource-card {
  display: flex; flex-direction: column;
  background: rgba(255,255,255,0.04);
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 12px; padding: 20px;
  text-decoration: none; color: inherit;
  transition: all 0.25s ease; cursor: pointer;
}
.resource-card:hover {
  background: rgba(194,27,27,0.1);
  border-color: rgba(194,27,27,0.35);
  transform: translateY(-2px);
}
.resource-icon {
  width: 40px; height: 40px; border-radius: 10px;
  background: var(--red); display: flex; align-items: center; justify-content: center;
  font-size: 1.1rem; margin-bottom: 14px; flex-shrink: 0;
}
.resource-title {
  font-family: 'Inter', sans-serif;
  font-size: 0.82rem; font-weight: 700;
  color: var(--light); margin-bottom: 5px;
  line-height: 1.3;
}
.resource-desc {
  font-family: 'Inter', sans-serif;
  font-size: 0.72rem; color: var(--gray); line-height: 1.5;
  flex: 1;
}
.resource-arrow {
  margin-top: 12px;
  font-family: 'Inter', sans-serif;
  font-size: 0.65rem; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  color: var(--red);
}

/* ── NAV BOTTOM ── */
.day-nav {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 56px; padding-top: 28px;
  border-top: 1px solid var(--border);
}
.day-nav-btn {
  display: flex; align-items: center; gap: 10px;
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  color: var(--light); font-family: 'Inter', sans-serif;
  font-size: 0.75rem; padding: 10px 18px; border-radius: 10px;
  cursor: pointer; text-decoration: none;
  transition: all 0.2s ease;
}
.day-nav-btn:hover { background: rgba(194,27,27,0.2); border-color: rgba(194,27,27,0.4); }
.day-nav-btn:disabled, .day-nav-btn.disabled {
  opacity: 0.3; pointer-events: none;
}
.day-nav-label {
  font-size: 0.65rem; color: var(--gray); line-height: 1.3;
}
.day-nav-title {
  font-size: 0.8rem; font-weight: 600; color: var(--light);
}

/* ── MARK COMPLETE ── */
.complete-btn {
  display: flex; align-items: center; gap: 8px;
  background: none; border: 1px solid #16a34a;
  color: #4ade80; font-family: 'Inter', sans-serif;
  font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em;
  padding: 10px 18px; border-radius: 100px;
  cursor: pointer; transition: all 0.2s ease;
}
.complete-btn:hover { background: rgba(22,163,74,0.15); }
.complete-btn.done { background: rgba(22,163,74,0.2); }



/* ── AUTH / PERSONAL PROGRESS ── */
.user-pill {
  display: none; align-items: center; gap: 8px;
  font-family: 'Inter', sans-serif; font-size: 0.72rem;
  color: rgba(242,239,233,0.75);
  background: rgba(255,255,255,0.05);
  border: 1px solid var(--border);
  border-radius: 100px; padding: 8px 12px;
  max-width: 210px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.btn-auth-top {
  display: flex; align-items: center; gap: 6px;
  background: transparent; color: var(--light);
  font-family: 'Inter', sans-serif; font-size: 0.7rem; font-weight: 600;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 8px 14px; border-radius: 100px; text-decoration: none;
  transition: all 0.2s ease; border: 1px solid var(--border); cursor: pointer;
  white-space: nowrap;
}
.btn-auth-top:hover { background: rgba(255,255,255,0.08); border-color: rgba(255,255,255,0.2); }
.auth-overlay {
  display: none; position: fixed; inset: 0; z-index: 1000;
  background: rgba(0,0,0,0.75); backdrop-filter: blur(8px);
  align-items: center; justify-content: center; padding: 20px;
}
.auth-overlay.open { display: flex; }
.auth-card {
  width: min(100%, 440px);
  background: var(--light); color: var(--dark);
  border-radius: 18px; overflow: hidden;
  box-shadow: 0 30px 100px rgba(0,0,0,0.45);
}
.auth-card-bar { height: 6px; background: var(--red); }
.auth-card-inner { padding: 30px; }
.auth-card h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2rem; line-height: 1.1; margin-bottom: 8px;
}
.auth-card p {
  font-family: 'Inter', sans-serif; font-size: 0.85rem;
  color: #4b5563; line-height: 1.6; margin-bottom: 20px;
}
.auth-field { margin-bottom: 14px; }
.auth-field label {
  display: block; font-family: 'Inter', sans-serif; font-size: 0.7rem;
  text-transform: uppercase; letter-spacing: 0.12em; color: #6b7280; margin-bottom: 6px;
}
.auth-input {
  width: 100%; border: 1px solid #d1d5db; border-radius: 10px;
  padding: 12px 14px; font-family: 'Inter', sans-serif; font-size: 0.95rem;
  outline: none; background: white; color: var(--dark);
}
.auth-input:focus { border-color: var(--red); box-shadow: 0 0 0 3px rgba(194,27,27,0.12); }
.auth-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 18px; }
.auth-primary, .auth-secondary {
  flex: 1; min-width: 140px; border-radius: 100px; padding: 12px 16px;
  font-family: 'Inter', sans-serif; font-weight: 700; font-size: 0.78rem;
  text-transform: uppercase; letter-spacing: 0.08em; cursor: pointer;
  transition: all 0.2s ease;
}
.auth-primary { background: var(--red); color: white; border: 1px solid var(--red); }
.auth-primary:hover { background: var(--dark); border-color: var(--dark); }
.auth-secondary { background: transparent; color: var(--dark); border: 1px solid #d1d5db; }
.auth-secondary:hover { border-color: var(--dark); }
.auth-close {
  width: 100%; margin-top: 12px; background: none; border: none; color: #6b7280;
  font-family: 'Inter', sans-serif; font-size: 0.82rem; cursor: pointer;
}
.auth-message {
  display: none; margin-top: 14px; padding: 10px 12px; border-radius: 8px;
  background: rgba(194,27,27,0.08); color: var(--red);
  font-family: 'Inter', sans-serif; font-size: 0.8rem; line-height: 1.4;
}
.auth-message.show { display: block; }
@media (max-width: 768px) {
  .user-pill { display: none !important; }
  .btn-auth-top { padding: 8px 10px; font-size: 0.65rem; }
}

/* ── MOBILE ── */
.sidebar-overlay {
  display: none; position: fixed; inset: 0; z-index: 90;
  background: rgba(0,0,0,0.7); backdrop-filter: blur(4px);
}
@media (max-width: 768px) {
  .topnav-brand { min-width: unset; }
  .sidebar {
    position: fixed; left: -100%; top: var(--header-h);
    height: calc(100vh - var(--header-h)); z-index: 95;
    transition: left 0.3s ease;
  }
  .sidebar.open { left: 0; }
  .sidebar-overlay.open { display: block; }
  .hamburger { display: flex; align-items: center; }
  .main-content { padding: 24px 20px 60px; }
  .progress-container { display: none; }
  .topnav-day-indicator { display: none; }
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: #050A14; }
::-webkit-scrollbar-thumb { background: #1a1a2e; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: var(--red); }
</style>
</head>
<body>

<!-- TOP NAV -->
<nav class="topnav">
  <a href="https://mustardseed.com.ng" class="topnav-brand">
    <div class="topnav-brand-text">
      <span class="topnav-brand-name">Mustard Seed</span>
      <span class="topnav-brand-course">School of Spiritual Growth</span>
    </div>
  </a>
  <div class="topnav-center">
    <div class="progress-container">
      <div class="progress-label">
        <span>Your Progress</span>
        <span id="progress-text">0 of 90 days</span>
      </div>
      <div class="progress-bar-track">
        <div class="progress-bar-fill" id="progress-fill" style="width:0%"></div>
      </div>
    </div>
    <span class="topnav-day-indicator" id="current-day-indicator">Day 1 of 90</span>
  </div>
  <div class="topnav-actions">
    <span class="user-pill" id="user-pill"></span>
    <button class="btn-auth-top" id="auth-btn" type="button">Log In</button>
    <button class="btn-auth-top" id="logout-btn" type="button" style="display:none;">Log Out</button>
    <a href="https://mustardseed.com.ng/journal" target="_blank" class="btn-journal-top">
      ✍️ Submit Journal
    </a>
    <button class="hamburger" id="hamburger-btn" aria-label="Menu">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="3" y1="6" x2="19" y2="6"/>
        <line x1="3" y1="11" x2="19" y2="11"/>
        <line x1="3" y1="16" x2="19" y2="16"/>
      </svg>
    </button>
  </div>
</nav>

<div class="sidebar-overlay" id="sidebar-overlay"></div>

<div class="auth-overlay" id="auth-overlay" aria-hidden="true">
  <div class="auth-card" role="dialog" aria-modal="true" aria-labelledby="auth-title">
    <div class="auth-card-bar"></div>
    <div class="auth-card-inner">
      <h2 id="auth-title">Personal Progress Login</h2>
      <p>Create an account or log in to save your completed days and continue your 90-day journey from any device.</p>
