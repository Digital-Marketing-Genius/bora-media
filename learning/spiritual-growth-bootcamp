function navigateToDay(dayNum, updateHistory = true) {
  if (dayNum < 1 || dayNum > 90) return;
  currentDay = dayNum;
  
  // Update URL hash
  if (updateHistory) {
    history.pushState(null, '', '#day-' + dayNum);
  }
  
  // Update sidebar
  document.querySelectorAll('.day-item').forEach(el => {
    const d = parseInt(el.getAttribute('data-day'));
    el.classList.toggle('active', d === dayNum);
  });
  
  // Ensure section is expanded and scroll day into view
  const activeItem = document.querySelector('.day-item.active');
  if (activeItem) {
    const group = activeItem.closest('.section-group');
    if (group && group.classList.contains('section-collapsed')) {
      group.classList.remove('section-collapsed');
    }
    setTimeout(() => activeItem.scrollIntoView({ block: 'nearest', behavior: 'smooth' }), 100);
  }
  
  // Update progress
  updateProgress();
  if (isProgressLoaded) {
    saveCloudProgress().catch(error => console.warn('Could not save last viewed day:', error));
  }
  
  // Render content
  renderDay(dayNum);
  
  // Update top indicator
  document.getElementById('current-day-indicator').textContent = `Day ${dayNum} of 90`;
}

async function toggleComplete(dayNum) {
  if (FIREBASE_ENABLED && !currentUser) {
    openAuthModal();
    return;
  }
  if (completedDays.has(dayNum)) {
    completedDays.delete(dayNum);
  } else {
    completedDays.add(dayNum);
    // Auto-advance to next if exists
    if (dayNum < 90) {
      setTimeout(() => navigateToDay(dayNum + 1), 600);
    }
  }
  try {
    await saveCloudProgress();
  } catch (error) {
    console.error('Could not save progress:', error);
    alert('Your progress could not be saved online. Please check your connection and Firebase setup.');
  }
  updateProgress();
  buildSidebar();
  
  const btn = document.getElementById('complete-btn');
  if (btn) {
    btn.textContent = completedDays.has(dayNum) ? '✓ Completed' : '○ Mark as Complete';
    btn.classList.toggle('done', completedDays.has(dayNum));
  }
}

function updateProgress() {
  const pct = (completedDays.size / 90) * 100;
  document.getElementById('progress-fill').style.width = pct + '%';
  document.getElementById('progress-text').textContent = `${completedDays.size} of 90 days`;
}

// ── SEARCH ───────────────────────────────────────────────
document.getElementById('search-input').addEventListener('input', function() {
  searchQuery = this.value.toLowerCase().trim();
  buildSidebar();
});

// ── MOBILE MENU ──────────────────────────────────────────
function closeMobileSidebar() {
  document.getElementById('sidebar').classList.remove('open');
  document.getElementById('sidebar-overlay').classList.remove('open');
}

document.getElementById('hamburger-btn').addEventListener('click', () => {
  document.getElementById('sidebar').classList.toggle('open');
  document.getElementById('sidebar-overlay').classList.toggle('open');
});
document.getElementById('sidebar-overlay').addEventListener('click', closeMobileSidebar);

// ── HASH ROUTING ─────────────────────────────────────────
function loadFromHash() {
  const hash = window.location.hash;
  const m = hash.match(/day-(\d+)/);
  if (m) {
    const d = parseInt(m[1]);
    if (d >= 1 && d <= 90) return d;
  }
  return 1;
}

window.addEventListener('popstate', () => {
  const d = loadFromHash();
  navigateToDay(d, false);
});


// ── FIREBASE / AUTH / CLOUD PROGRESS ─────────────────────
function showAuthMessage(message, isSuccess = false) {
  const el = document.getElementById('auth-message');
  if (!el) return;
  el.textContent = message;
  el.classList.add('show');
  el.style.background = isSuccess ? 'rgba(22,163,74,0.10)' : 'rgba(194,27,27,0.08)';
  el.style.color = isSuccess ? '#166534' : 'var(--red)';
}

function clearAuthMessage() {
  const el = document.getElementById('auth-message');
  if (!el) return;
  el.textContent = '';
  el.classList.remove('show');
}

function openAuthModal() {
  const overlay = document.getElementById('auth-overlay');
  if (!overlay) return;
  clearAuthMessage();
  overlay.classList.add('open');
  overlay.setAttribute('aria-hidden', 'false');
  setTimeout(() => document.getElementById('auth-email')?.focus(), 50);

  if (!FIREBASE_ENABLED) {
    showAuthMessage('Firebase is not connected yet. Add your Firebase config inside the HTML file before login and signup will work.');
  }
}

function closeAuthModal() {
  const overlay = document.getElementById('auth-overlay');
  if (!overlay) return;
  overlay.classList.remove('open');
  overlay.setAttribute('aria-hidden', 'true');
}

function getFriendlyAuthError(error) {
  const code = error && error.code ? error.code : '';
  const map = {
    'auth/invalid-email': 'Please enter a valid email address.',
    'auth/missing-password': 'Please enter your password.',
    'auth/weak-password': 'Password should be at least 6 characters.',
    'auth/email-already-in-use': 'An account already exists with this email. Try logging in instead.',
    'auth/user-not-found': 'No account was found with this email. Create an account first.',
    'auth/wrong-password': 'Incorrect password. Please try again.',
    'auth/invalid-credential': 'The email or password is incorrect, or this account does not exist yet.',
    'auth/network-request-failed': 'Network error. Please check your connection and try again.',
    'auth/operation-not-allowed': 'Email/password login is not enabled in Firebase Authentication.'
  };
  return map[code] || (error && error.message ? error.message : 'Something went wrong. Please try again.');
}

function setAuthUi(user) {
  const authBtn = document.getElementById('auth-btn');
  const logoutBtn = document.getElementById('logout-btn');
  const userPill = document.getElementById('user-pill');

  if (user) {
    authBtn.style.display = 'none';
    logoutBtn.style.display = 'flex';
    userPill.style.display = 'flex';
    userPill.textContent = user.email || 'Logged in';
  } else {
    authBtn.style.display = 'flex';
    logoutBtn.style.display = 'none';
    userPill.style.display = 'none';
    userPill.textContent = '';
  }
}

function initFirebaseAuth() {
  if (!FIREBASE_ENABLED) {
    console.warn('Firebase is not enabled. Replace FIREBASE_CONFIG placeholders with your Firebase web app config.');
    isProgressLoaded = true;
    setAuthUi(null);
    return;
  }

  try {
    if (!firebase.apps.length) {
      firebase.initializeApp(FIREBASE_CONFIG);
    }
    auth = firebase.auth();
    db = firebase.firestore();

    auth.onAuthStateChanged(async (user) => {
      currentUser = user || null;
      setAuthUi(currentUser);

      if (currentUser) {
        await loadCloudProgress();
        closeAuthModal();
      } else {
        completedDays = new Set(JSON.parse(localStorage.getItem('ssg_completed_guest') || '[]'));
        isProgressLoaded = true;
      }

      updateProgress();
      buildSidebar();
      renderDay(currentDay);
    });
  } catch (error) {
    console.error('Firebase initialization failed:', error);
    isProgressLoaded = true;
    setAuthUi(null);
    showAuthMessage('Firebase could not start. Check that your Firebase config was pasted correctly.');
  }
}

async function loginUser() {
  if (!FIREBASE_ENABLED || !auth) {
    showAuthMessage('Firebase is not connected yet. Paste your Firebase config into the HTML file first.');
    return;
  }

  const email = document.getElementById('auth-email').value.trim();
  const password = document.getElementById('auth-password').value;

  if (!email || !password) {
    showAuthMessage('Please enter both email and password.');
    return;
  }

  try {
    showAuthMessage('Logging you in...', true);
    await auth.signInWithEmailAndPassword(email, password);
  } catch (error) {
    showAuthMessage(getFriendlyAuthError(error));
  }
}

async function signupUser() {
  if (!FIREBASE_ENABLED || !auth) {
    showAuthMessage('Firebase is not connected yet. Paste your Firebase config into the HTML file first.');
    return;
  }

  const email = document.getElementById('auth-email').value.trim();
  const password = document.getElementById('auth-password').value;

  if (!email || !password) {
    showAuthMessage('Please enter both email and password.');
    return;
  }

  try {
    showAuthMessage('Creating your account...', true);
    const result = await auth.createUserWithEmailAndPassword(email, password);
    currentUser = result.user;
    await saveCloudProgress();
  } catch (error) {
    showAuthMessage(getFriendlyAuthError(error));
  }
}

async function logoutUser() {
  if (auth) {
    await auth.signOut();
  }
}

async function loadCloudProgress() {
  if (!db || !currentUser) return;

  const ref = db.collection('users').doc(currentUser.uid);
  const snap = await ref.get();

  if (snap.exists) {
    const data = snap.data() || {};
    completedDays = new Set(Array.isArray(data.completedDays) ? data.completedDays : []);
    if (typeof data.lastViewedDay === 'number' && data.lastViewedDay >= 1 && data.lastViewedDay <= 90) {
      currentDay = data.lastViewedDay;
      history.replaceState(null, '', '#day-' + currentDay);
    }
  } else {
    const guestProgress = JSON.parse(localStorage.getItem('ssg_completed_guest') || '[]');
    completedDays = new Set(guestProgress);
    await ref.set({
      email: currentUser.email || '',
      completedDays: Array.from(completedDays),
      lastViewedDay: currentDay,
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      updatedAt: firebase.firestore.FieldValue.serverTimestamp()
    }, { merge: true });
  }

  isProgressLoaded = true;
}

async function saveCloudProgress() {
  const daysArray = Array.from(completedDays).sort((a, b) => a - b);

  if (!FIREBASE_ENABLED || !db || !currentUser) {
    localStorage.setItem('ssg_completed_guest', JSON.stringify(daysArray));
    return;
  }

  await db.collection('users').doc(currentUser.uid).set({
    email: currentUser.email || '',
    completedDays: daysArray,
    lastViewedDay: currentDay,
    updatedAt: firebase.firestore.FieldValue.serverTimestamp()
  }, { merge: true });
}

// ── AUTH EVENTS ───────────────────────────────────────────
document.getElementById('auth-btn').addEventListener('click', openAuthModal);
document.getElementById('logout-btn').addEventListener('click', logoutUser);
document.getElementById('auth-close').addEventListener('click', closeAuthModal);
document.getElementById('auth-overlay').addEventListener('click', (e) => {
  if (e.target.id === 'auth-overlay') closeAuthModal();
});
document.getElementById('login-btn').addEventListener('click', loginUser);
document.getElementById('signup-btn').addEventListener('click', signupUser);
document.getElementById('auth-password').addEventListener('keydown', (e) => {
  if (e.key === 'Enter') loginUser();
});

// ── INIT ─────────────────────────────────────────────────
(function init() {
  initFirebaseAuth();
  buildSidebar();
  updateProgress();
  const startDay = loadFromHash();
  navigateToDay(startDay, false);
})();
</script>
