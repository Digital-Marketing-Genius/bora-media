// ── SIDEBAR ──────────────────────────────────────────────
function buildSidebar() {
  const container = document.getElementById('sidebar-content');
  container.innerHTML = '';
  
  SECTIONS.forEach((sec, si) => {
    const filteredDays = sec.days.filter(d => {
      const day = DAYS.find(x => x.day === d);
      if (!day) return false;
      if (!searchQuery) return true;
      return (
        day.title.toLowerCase().includes(searchQuery) ||
        `day ${d}`.includes(searchQuery)
      );
    });
    if (filteredDays.length === 0) return;
    
    const isCollapsed = sectionStates[si] === false;
    const group = document.createElement('div');
    group.className = 'section-group' + (isCollapsed ? ' section-collapsed' : '');
    
    const titleEl = document.createElement('div');
    titleEl.className = 'section-title';
    titleEl.innerHTML = `<span>${sec.title}</span><span class="section-chevron">▾</span>`;
    titleEl.addEventListener('click', () => {
      group.classList.toggle('section-collapsed');
      sectionStates[si] = !group.classList.contains('section-collapsed');
      localStorage.setItem('ssg_sections', JSON.stringify(sectionStates));
    });
    
    const daysContainer = document.createElement('div');
    daysContainer.className = 'section-days';
    
    filteredDays.forEach(d => {
      const day = DAYS.find(x => x.day === d);
      if (!day) return;
      const item = document.createElement('div');
      item.className = 'day-item' + (d === currentDay ? ' active' : '') + (completedDays.has(d) ? ' completed' : '');
      item.setAttribute('data-day', d);
      item.innerHTML = `
        <div class="day-num-badge">${completedDays.has(d) ? '✓' : d}</div>
        <div class="day-item-title">${day.title}</div>
      `;
      item.addEventListener('click', () => {
        navigateToDay(d);
        // Close mobile sidebar
        closeMobileSidebar();
      });
      daysContainer.appendChild(item);
    });
    
    // Set max-height for animation
    daysContainer.style.maxHeight = isCollapsed ? '0' : '10000px';
    
    group.appendChild(titleEl);
    group.appendChild(daysContainer);
    container.appendChild(group);
  });
}

