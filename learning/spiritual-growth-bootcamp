        </div>
        <a href="https://mustardseed.com.ng/journal" target="_blank" class="btn-journal">
          Submit Journal →
        </a>
      </div>
    </div>

    <div class="resources-section">
      <div class="section-heading">Other Resources</div>
      <div class="resources-grid">
        ${resourcesHTML}
