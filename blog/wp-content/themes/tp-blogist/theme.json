{
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"settings": {
		"appearanceTools": true,
		"color": {
			"duotone": [
				{
					"colors": [
						"#00a0d2",
						"#0073aa"
					],
					"name": "Secondary and primary",
					"slug": "secondary-primary"
				},
				{
					"colors": [
						"#0073aa",
						"#2b2b2b"
					],
					"name": "Primary and Contrast",
					"slug": "primary-contrast"
				}
			],
			"gradients": [
				{
					"gradient": "linear-gradient(#0073aa 49.9%,#fff 50%)",
					"name": "Primary color to white",
					"slug": "primary-white"
				},
				{
					"gradient": "linear-gradient(#fff 49.9%,#0073aa 50%)",
					"name": "Horizontal white to Primary color",
					"slug": "white-primary"
				}
			],
			"palette": [
				{
					"color": "#ffffff",
					"name": "Base",
					"slug": "base"
				},
				{
					"color": "#2b2b2b",
					"name": "Contrast",
					"slug": "contrast"
				},
				{
					"color": "#091057",
					"name": "Primary",
					"slug": "primary"
				},
				{
					"color": "#024caa",
					"name": "Secondary",
					"slug": "secondary"
				},
				{
					"color": "transparent",
					"name": "Transparent",
					"slug": "transparent"
				},
				{
					"color": "#f8f9fa",
					"name": "background",
					"slug": "custom-background"
				},
				{
					"color": "#111111",
					"name": "Color",
					"slug": "custom-color"
				},
				{
					"color": "#3a86ff",
					"name": "accent",
					"slug": "custom-accent"
				}
			]
		},
		"layout": {
			"contentSize": "900px",
			"wideSize": "1320px"
		},
		"spacing": {
			"units": [
				"px",
				"em",
				"rem",
				"vh",
				"vw",
				"%"
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"dropCap": false,
			"fluid": true,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Poppins",
							"fontStyle": "normal",
							"fontWeight": "500",
							"src": "file:./assets/fonts/poppins/poppins.woff2"
						}
					],
					"fontFamily": "Poppins, sans-serif",
					"name": "Poppins",
					"slug": "poppins"
				},
				{
					"fontFace": [
						{
							"fontFamily": "Roboto",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": "file:./assets/fonts/roboto/roboto.woff2"
						}
					],
					"fontFamily": "Roboto, sans-serif",
					"name": "Roboto",
					"slug": "roboto"
				}
			],
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "1.125rem",
					"slug": "small"
				},
				{
					"fluid": false,
					"name": "Medium",
					"size": "1.5rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "2rem",
						"min": "1.75rem"
					},
					"name": "Large",
					"size": "2rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2.75rem",
						"min": "2.5rem"
					},
					"name": "XL",
					"size": "2.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3.75rem",
						"min": "3rem"
					},
					"name": "XXL",
					"size": "3.75rem",
					"slug": "xx-large"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"blocks": {
			"core/code": {
				"color": {
					"text": "var(--wp--preset--color--contrast)"
				}
			},
			"core/comment-author-name": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-date": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-edit-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/comment-reply-link": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/heading": {
				"typography": {
					"lineHeight": "1.3"
				}
			},
			"core/navigation": {
				"css": "& .wp-block-site-title{ margin:0; font-weight:400;}",
				"elements": {
					"link": {
						":active": {
							"color": {
								"text": "var(--wp--preset--color--contrast)"
							}
						},
						":focus": {
							"color": {
								"text": "var(--wp--preset--color--contrast)"
							}
						},
						":hover": {
							"color": {
								"text": "var(--wp--preset--color--contrast)"
							},
							"typography": {
								"textDecoration": "none"
							}
						},
						"color": {
							"text": "var(--wp--preset--color--contrast)"
						},
						"typography": {
							"textDecoration": "underline"
						}
					}
				}
			},
			"core/post-author-name": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-comments-form": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-content": {
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--60)",
						"top": "var(--wp--preset--spacing--60)"
					}
				}
			},
			"core/post-date": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-excerpt": {
				"elements": {
					"link": {
						"typography": {
							"fontSize": "var(--wp--preset--font-size--small)"
						}
					}
				}
			},
			"core/post-featured-image": {
				"spacing": {
					"margin": {
						"bottom": "var(--wp--preset--spacing--40)"
					}
				}
			},
			"core/post-template": {
				"spacing": {
					"blockGap": "var(--wp--preset--spacing--60)",
					"padding": {
						"bottom": "var(--wp--preset--spacing--50)",
						"top": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/post-terms": {
				"typography": {
					"fontSize": "var(--wp--preset--font-size--small)"
				}
			},
			"core/post-title": {
				"typography": {
					"lineHeight": "1.3"
				}
			},
			"core/query-pagination": {
				"spacing": {
					"padding": {
						"top": "var(--wp--preset--spacing--50)"
					}
				}
			},
			"core/search": {
				"css": ".wp-block-search__button-inside .wp-block-search__inside-wrapper{border: none;}",
				"typography": {
					"lineHeight": "1"
				}
			}
		},
		"color": {
			"background": "var(--wp--preset--color--custom-background)",
			"text": "var(--wp--preset--color--custom-color)"
		},
		"css": "\n .wp-block-post-title a:hover {\n    color: #3A86FF !important;\n}\n\n.wp-block-query-pagination a{\npadding: 10px 20px;\n  text-decoration: none; \n background: #87B4FD;\nborder-radius: 10px;\ncolor:#ffffff;\n}\n.wp-block-query-pagination span{\npadding: 10px 20px;\n    background: #3A86FF;\nborder-radius: 10px;\ncolor:#ffffff;\n}\n.page-numbers.current{\ncolor:#ffffff!important;\n}\n.wp-block-navigation .wp-block-navigation-item__content.wp-block-navigation-item__content {\n    text-decoration: none;\n}\n@media only screen and (max-width: 1000px) {\n.wp-block-navigation__responsive-container-open:not(.always-shown) {\n        display: block !important;\n    }\nheader .wp-block-navigation__responsive-container{\ndisplay: none !important;\n}\nheader .wp-block-navigation__responsive-container.is-menu-open{\ndisplay: block !important;\n}\n}\n\n@media (max-width: 781px) {\n#banner-heading h5, h3, h1{\nfont-size: 22px!important;\n}\n.wrap-the-columns\n {\n  grid-template-columns: repeat(2, minmax(0, 1fr))!important;\n}\n\n\n}\n@media (max-width: 600px) {\n.wrap-the-columns\n{\n grid-template-columns: repeat(1, minmax(0, 1fr))!important;\n}\n#pt-latest .is-layout-flex {\nflex-wrap: wrap!important;\n}\n#banner .wp-block-cover{\nmin-height:300px!important;\n}\n#banner .margin-top{\n    margin-top: 200px!important;\n}\n#banner .wp-block-post-excerpt{\ndisplay:none;\n}\n.footer-subscribe{\npadding:0px!important;\n}\n}\n@media only screen and (max-width: 1000px) {\n  .mobile-disable{\n     display:none!important;\n  }\n}\n@media only screen and (max-width: 600px) {.splide__arrow{\n     display:none!important;\n  }\n}\n.input.wp-element-button, .wpcf7-submit, .wp-block-button__link, .wp-element-button {\n    background: #3A86FF!important;\n    border: none !important;\n    color: #fff !important;\n    font-size: 15px;\n    border-radius: 10px !important;\n    padding: 12px 24px !important;\n}\n.taxonomy-category a{\n    padding: 6px 12px;\n    background: #3A86FF;\n    text-decoration: none!important;\n    color: #ffffff!important;\nborder-radius: 5px;\nmargin-right: 6px;\n}\n.single .wp-block-post-terms a{\n padding: 6px 12px;\n    background: #3A86FF;\n    text-decoration: none!important;\n    color: #ffffff!important;\nborder-radius: 5px;\nmargin: 5px;\n}\n.wp-block-post-terms .wp-block-post-terms__separator {\n    display: none;\n}",
		"elements": {
			"button": {
				":hover": {
					"border": {
						"color": "var(--wp--preset--color--secondary)"
					}
				},
				"border": {
					"color": "var(--wp--preset--color--transparent)",
					"radius": "4px",
					"style": "solid",
					"width": "4px"
				},
				"color": {
					"background": "var(--wp--preset--color--primary)",
					"text": "var(--wp--preset--color--contrast)"
				},
				"shadow": "var(--wp--preset--shadow--natural)",
				"spacing": {
					"padding": {
						"bottom": "var(--wp--preset--spacing--30)",
						"left": "var(--wp--preset--spacing--30)",
						"right": "var(--wp--preset--spacing--30)",
						"top": "var(--wp--preset--spacing--30)"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--roboto)",
					"fontSize": "var(--wp--preset--font-size--small)",
					"fontStyle": "italic",
					"fontWeight": "700"
				}
			},
			"caption": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--roboto)"
				}
			},
			"cite": {
				"color": {
					"text": "var(--wp--preset--color--primary)"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "34px"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "26px"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "24px"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "22px"
				}
			},
			"h5": {
				"typography": {
					"fontSize": "20px"
				}
			},
			"h6": {
				"typography": {
					"fontSize": "18px"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--poppins)"
				}
			},
			"link": {
				":active": {
					"color": {
						"text": "var(--wp--preset--color--contrast)"
					}
				},
				":focus": {
					"color": {
						"text": "var(--wp--preset--color--contrast)"
					}
				},
				":hover": {
					"color": {
						"text": "var(--wp--preset--color--contrast)"
					},
					"typography": {
						"textDecoration": "none"
					}
				},
				"color": {
					"text": "var(--wp--preset--color--custom-color)"
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--roboto)"
				}
			}
		},
		"spacing": {
			"padding": {
				"left": "var(--wp--preset--spacing--50)",
				"right": "var(--wp--preset--spacing--50)"
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--roboto)",
			"fontSize": "17px",
			"lineHeight": "1.7"
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "Header"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Footer"
		}
	],
	"version": 3
}